<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="502.0" prefWidth="741.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="parqueadero_parkuq.viewController.OperaReporteViewController">
    <children>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Reporte Diario del Parqueadero">
                    <font>
                        <Font name="Times New Roman" size="25.0" />
                    </font>
                </Text>
                <Separator prefWidth="200.0" />
                <Button mnemonicParsing="false" onAction="#onGenerarReporte" text="Generar Reporte del Día">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
                <TableView fx:id="tableReporte" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="tcConcepto" prefWidth="250.0" text="Concepto" />
                        <TableColumn fx:id="tcValor" prefWidth="450.0" text="Valor" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>